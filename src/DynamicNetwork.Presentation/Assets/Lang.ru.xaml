    <sys:String x:Key="TabFunctionalLibrary">Функциональная библиотека</sys:String>
    <sys:String x:Key="TabConfigurations">Конфигурации</sys:String>

    <!-- Intervals Tab -->
    <sys:String x:Key="TitleStructurePersistenceIntervals">Интервалы постоянства структуры</sys:String>
    <sys:String x:Key="LblDuration">Длина:</sys:String>
    <sys:String x:Key="LblLinkCount">соединений</sys:String>
    <sys:String x:Key="TitleSelectedInterval">Выбранный интервал</sys:String>

