    <sys:String x:Key="LblAllowedProcesses">Разрешенные процессы:</sys:String>
    <sys:String x:Key="LblAllowedTransports">Разрешенные транспорты:</sys:String>

    <sys:String x:Key="TitleLinkConfigurations">Конфигурации соединений</sys:String>
    <sys:String x:Key="TitleLinkSettings">Настройки соединения</sys:String>
    <sys:String x:Key="LblNodeA">Узел A:</sys:String>
    <sys:String x:Key="LblNodeB">Узел B:</sys:String>

