<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
                    xmlns:sys="clr-namespace:System;assembly=mscorlib">

    <!-- General -->
    <sys:String x:Key="AppTitle">Dynamic Network</sys:String>

    <!-- Top Panel -->
    <sys:String x:Key="BtnLoadFile">Загрузить файл</sys:String>
    <sys:String x:Key="BtnExport">Экспорт</sys:String>
    <sys:String x:Key="LblInterval">Интервал:</sys:String>

    <!-- Left Sidebar -->
    <sys:String x:Key="TitleAllVertices">Все устройства</sys:String>
    <sys:String x:Key="LblProcesses">Процессы:</sys:String>
    <sys:String x:Key="LblInputs">Входы:</sys:String>
    <sys:String x:Key="LblOutputs">Выходы:</sys:String>
    <sys:String x:Key="LblStorages">Хранилища:</sys:String>

    <!-- Main Tabs -->
    <sys:String x:Key="TabIntervals">Интервалы</sys:String>
    <sys:String x:Key="TabConnections">Соединения</sys:String>
