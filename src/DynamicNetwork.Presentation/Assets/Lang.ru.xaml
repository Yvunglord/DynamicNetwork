    <sys:String x:Key="TitleProcessManagement">Управление процессами</sys:String>
    <sys:String x:Key="LblProcessId">ID процесса:</sys:String>
    <sys:String x:Key="LblProcessingTime">Время обработки:</sys:String>
    <sys:String x:Key="LblInputFlowType">Тип входного потока:</sys:String>
