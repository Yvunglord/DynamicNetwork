    <sys:String x:Key="TitleTransportManagement">Управление транспортом</sys:String>
    <sys:String x:Key="LblTransportId">ID транспорта:</sys:String>
    <sys:String x:Key="LblTransmissionTime">Время передачи:</sys:String>
    <sys:String x:Key="LblFlowType">Тип потока:</sys:String>
