    <sys:String x:Key="HintLanguageChange">Изменения применяются сразу</sys:String>

    <sys:String x:Key="TitleSettingsGeneral">Общие</sys:String>
    <sys:String x:Key="HintMoreSettingsSoon">Дополнительные настройки скоро появятся</sys:String>

    <!-- Tips -->
    <sys:String x:Key="TipChangeDirection">Изменить направление связи</sys:String>
    <sys:String x:Key="TipChangeDirectionUndirected">Сделать связь ненаправленной</sys:String>

</ResourceDictionary>